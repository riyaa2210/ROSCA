# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build output (Render generates this during deploy) ────────────────────────
server/public/
client/dist/
dist/

# ── Environment files (NEVER commit secrets) ──────────────────────────────────
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local
server/.env
client/.env.production
client/.env.local

# ── Uploads (use cloud storage in prod) ───────────────────────────────────────
server/uploads/*
!server/uploads/.gitkeep

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
npm-debug.log*
.vscode/
.idea/
